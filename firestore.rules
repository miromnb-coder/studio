rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SECURE FINANCIAL ANALYSIS RULES
     *
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. Every piece of data is 
     * functionally and logically tied to a specific UserProfile via hierarchical 
     * nesting and denormalized identity fields.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function matchesPath(field, pathValue) {
      return request.resource.data[field] == pathValue;
    }

    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && matchesPath('id', userId);
      allow update, delete: if isExistingOwner(userId) && isUnchanged('id');
      
      /**
       * @description User chat threads and persistent memory.
       * @path /users/{userId}/conversations/{conversationId}
       */
      match /conversations/{conversationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update, delete: if isExistingOwner(userId) && isUnchanged('userId');

        /**
         * @description Individual messages within a conversation.
         */
        match /messages/{messageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update, delete: if isExistingOwner(userId);
        }
      }

      match /settings/{settingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /uploaded_files/{fileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /analyses/{analysisId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        match /detected_items/{detectedItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && matchesPath('userId', userId) && matchesPath('analysisId', analysisId);
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('analysisId');
          allow delete: if isExistingOwner(userId);

          match /recommended_actions/{actionId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && matchesPath('userId', userId) && matchesPath('analysisId', analysisId) && matchesPath('detectedItemId', detectedItemId);
            allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('analysisId') && isUnchanged('detectedItemId');
            allow delete: if isExistingOwner(userId);
          }
        }
      }

      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /alerts/{alertId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      match /inbox/{emailId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}