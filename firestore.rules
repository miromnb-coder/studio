rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SECURE FINANCIAL ANALYSIS RULES
     *
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. Every piece of data is 
     * functionally and logically tied to a specific UserProfile via hierarchical 
     * nesting and denormalized identity fields.
     *
     * Data Structure: 
     * All application data is segregated under the path /users/{userId}. 
     * This includes settings, uploaded files, financial analyses, and alerts.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: The primary check for all operations is whether the 
     *    authenticated user's UID matches the {userId} wildcard in the document path.
     * 2. Denormalization for Performance: High-depth subcollections (DetectedItems, 
     *    RecommendedActions) store the 'userId' and parent IDs directly. This allows 
     *    rules to remain fast and avoid expensive get() calls to parent documents.
     * 3. Relational Integrity: Upon creation, documents are forced to include a 'userId' 
     *    field that matches the path, and these fields are immutable thereafter.
     * 4. Prototyping Flexibility: While ownership is strictly enforced, the specific 
     *    content schema (strings vs. numbers, etc.) is left flexible to allow for 
     *    rapid feature iteration.
     */

    // --- Global Helper Functions ---

    /**
     * @description Checks if the request is from a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner and the document exists.
     * Used for update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Validates that a field in the incoming data matches the path wildcard.
     * Used to ensure relational consistency on creation.
     */
    function matchesPath(field, pathValue) {
      return request.resource.data[field] == pathValue;
    }

    /**
     * @description Verifies that a specific field remains unchanged during an update.
     */
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root UserProfile document.
     * @path /users/{userId}
     * @allow (create) User with UID '123' creating /users/123.
     * @deny (create) User with UID '123' creating /users/456.
     * @principle Self-creation and strict ownership of the root user profile.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot be listed for privacy.
      allow create: if isOwner(userId) && matchesPath('id', userId);
      allow update, delete: if isExistingOwner(userId) && isUnchanged('id');
      
      /**
       * @description Stores user-specific preferences and interface settings.
       * @path /users/{userId}/settings/{settingId}
       * @allow (get) Owner viewing their own UI preferences.
       * @deny (list) Anonymous user attempting to list a user's settings.
       * @principle Hierarchical ownership for private configuration data.
       */
      match /settings/{settingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Metadata for files uploaded for analysis.
       * @path /users/{userId}/uploaded_files/{fileId}
       * @allow (create) Owner linking a file metadata doc to their account.
       * @deny (update) Attempting to change the userId of an existing file record.
       * @principle Ensures file metadata remains associated with the original uploader.
       */
      match /uploaded_files/{fileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Financial analysis reports.
       * @path /users/{userId}/analyses/{analysisId}
       * @allow (list) Owner viewing their history of financial analyses.
       * @deny (delete) User 'A' attempting to delete User 'B's analysis.
       * @principle Restricted access to sensitive financial calculations.
       */
      match /analyses/{analysisId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Specific findings detected within an analysis.
         * @path /users/{userId}/analyses/{analysisId}/detected_items/{detectedItemId}
         * @allow (create) Analysis service adding a finding with correct parent IDs.
         * @deny (create) Mismatched analysisId between path and document body.
         * @principle Uses denormalized parent IDs to ensure deep relational integrity.
         */
        match /detected_items/{detectedItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && matchesPath('userId', userId) && matchesPath('analysisId', analysisId);
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('analysisId');
          allow delete: if isExistingOwner(userId);

          /**
           * @description Tasks or scripts recommended to resolve a detected item.
           * @path /users/{userId}/analyses/{analysisId}/detected_items/{detectedItemId}/recommended_actions/{actionId}
           * @allow (update) User marking a specific action as 'completed'.
           * @principle Validates deep hierarchy consistency without cross-document reads.
           */
          match /recommended_actions/{actionId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && matchesPath('userId', userId) && matchesPath('analysisId', analysisId) && matchesPath('detectedItemId', detectedItemId);
            allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('analysisId') && isUnchanged('detectedItemId');
            allow delete: if isExistingOwner(userId);
          }
        }
      }

      /**
       * @description Recurring charges or subscriptions managed by the user.
       * @path /users/{userId}/subscriptions/{subscriptionId}
       * @allow (update) Owner updating the cost of their Netflix subscription.
       * @principle Ownership-based management of recurring financial commitments.
       */
      match /subscriptions/{subscriptionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description System-generated notifications regarding financial health.
       * @path /users/{userId}/alerts/{alertId}
       * @allow (update) User dismissing an alert (setting isDismissed to true).
       * @principle Restricts alert visibility and interaction to the targeted user.
       */
      match /alerts/{alertId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && matchesPath('userId', userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}