
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AI LIFE OPERATOR - TIETOTURVASÄÄNNÖT
     * Sallii pääsyn omiin tietoihin auth.uid:n perusteella.
     * Sähköpostin vahvistusta ei vaadita perustoimintoihin.
     */

    // --- Globaalit apufunktiot ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      // Sallitaan pääsy, jos käyttäjä on kirjautunut ja UID täsmää
      // Emme vaadi request.auth.token.email_verified == true tässä vaiheessa
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Kokoelmien säännöt ---

    match /users/{userId} {
      // Käyttäjäprofiili
      allow get, create, update: if isOwner(userId);
      allow delete: if false; // Profiilin poisto vaatii manuaalisen tarkistuksen
      
      /**
       * @description Käyttömäärät ja kiintiöt.
       */
      match /usage/{date} {
        allow get, list, create, update: if isOwner(userId);
      }

      /**
       * @description Agentin pitkäaikainen muisti.
       */
      match /memory/main {
        allow get, create, update, delete: if isOwner(userId);
      }

      /**
       * @description Keskusteluhistoria.
       */
      match /conversations/{conversationId} {
        allow read, write: if isOwner(userId);
        
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      /**
       * @description Analyysiraportit ja löydetyt kohteet.
       */
      match /analyses/{analysisId} {
        allow read, write: if isOwner(userId);

        match /detected_items/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }

      /**
       * @description Hälytykset ja ilmoitukset.
       */
      match /alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Inbound-sähköpostit ja tiedonkeruu.
       */
      match /inbox/{emailId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Päivittäiset yhteenvedot.
       */
      match /digests/{digestId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Agent V5/V6: Dynaamisesti luodut työkalut.
       */
      match /forged_tools/{toolId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Agent V6: Episodinen muisti (tapahtumaloki).
       */
      match /episodic_memory/{eventId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
