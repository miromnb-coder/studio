
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Käyttäjän perustiedot ja tilaustaso.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "plan": { "type": "string", "enum": ["FREE", "STARTER", "PREMIUM"] },
        "inboundEmailAddress": { "type": "string" },
        "totalSavedOverall": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Usage": {
      "title": "Usage",
      "type": "object",
      "description": "Päivittäiset käyttömäärät.",
      "properties": {
        "agentRuns": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "Analysis": {
      "title": "Analysis",
      "type": "object",
      "description": "Yksittäinen taloudellinen analyysi.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "estimatedMonthlySavings": { "type": "number" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Käyttäjän profiili."
        }
      },
      {
        "path": "/users/{userId}/usage/{date}",
        "definition": {
          "entityName": "Usage",
          "schema": { "$ref": "#/backend/entities/Usage" },
          "description": "Käyttömäärät per päivä."
        }
      }
    ]
  }
}
