
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores core, non-authentication related information about a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "inboundEmailAddress": {
          "type": "string",
          "description": "Unique magic forwarding address for receipt processing."
        },
        "displayName": {
          "type": "string",
          "description": "The user's preferred display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "createdAt"
      ]
    },
    "Conversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Conversation",
      "type": "object",
      "description": "Stores a persistent chat session between the user and the Operator.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "An individual message within a conversation.",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "data": { "type": "object" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "Inbox": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inbox",
      "type": "object",
      "description": "Stores raw incoming email data for audit and processing.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "from": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "userId",
        "subject",
        "body",
        "receivedAt"
      ]
    },
    "Analysis": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Analysis",
      "type": "object",
      "description": "Represents a single instance of a financial analysis.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "source": { "type": "string", "enum": ["screenshot", "pasted_text", "email", "chat"] },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "estimatedMonthlySavings": { "type": "number" },
        "analysisDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "inputMethod": { "type": "string" },
        "inputContent": { "type": "string" },
        "beforeComparison": { "type": "string" },
        "afterComparison": { "type": "string" }
      },
      "required": [
        "id",
        "userId",
        "title",
        "summary",
        "estimatedMonthlySavings",
        "analysisDate",
        "status",
        "source"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores core profile information."
        }
      },
      {
        "path": "/users/{userId}/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "User chat threads."
        }
      },
      {
        "path": "/users/{userId}/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Messages within a conversation."
        }
      },
      {
        "path": "/users/{userId}/inbox/{emailId}",
        "definition": {
          "entityName": "Inbox",
          "schema": { "$ref": "#/backend/entities/Inbox" },
          "description": "Stores raw incoming emails."
        }
      },
      {
        "path": "/users/{userId}/analyses/{analysisId}",
        "definition": {
          "entityName": "Analysis",
          "schema": { "$ref": "#/backend/entities/Analysis" },
          "description": "Stores individual financial analysis reports."
        }
      }
    ]
  }
}
